{
  "redirects": [
    {
      "source": "/blog/adapalene-before-after-results/?",
      "destination": "/acne/adapalene-before-after-results/",
      "permanent": true
    },
    {
      "source": "/blog/adapalene-differin-adaferin-gel-comparison-india/?",
      "destination": "/acne/adapalene-differin-adaferin-gel-comparison-india/",
      "permanent": true
    },
    {
      "source": "/acne/ut-treatment-guide/?",
      "destination": "/acne/nose-pimple-treatments-home-remedies-clinical-cures/",
      "permanent": true
    },
    {
      "source": "/acne/nodule-vs-cyst/?",
      "destination": "/acne/nodule-cyst/",
      "permanent": true
    },
    {
      "source": "/blog/pimple-vs-zit-inflammatory-papules-pustules-indian-skin/?",
      "destination": "/acne/pimple-zit/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/scan",
      "destination": "https://face3layerscanner.onrender.com/"
    },
    {
      "source": "/scan/:path*",
      "destination": "https://face3layerscanner.onrender.com/:path*"
    },
    {
      "source": "/analyze-face",
      "destination": "https://face3layerscanner.onrender.com/analyze-face"
    },
    {
      "source": "/scan-log/:path*",
      "destination": "https://face3layerscanner.onrender.com/scan-log/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|png|webp|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}